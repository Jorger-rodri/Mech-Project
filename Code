def black_hole_simulation():
    """
    Simulacion interactiva 3D de una nave orbitando un agujero negro.

    Parametros ajustables:
    - Radio inicial (r0): distancia al agujero negro.
    - Velocidad tangencial (v0): modulo de la velocidad inicial.

    Muestra si la nave cae, orbita o escapa.
    Controles: Play, Pause, Reset via botones o teclado (P / R).
    """
    GM_bh   = 1.0
    horizon = 0.5

    # Velocidad visual incrementada (factor x4 respecto al original)
    speed = 80.0
    dt    = 0.01 * speed

    r0 = 3.0
    v0_init = np.sqrt(GM_bh / r0)

    sim_state = {
        "pos":       np.array([r0, 0.0, 0.0]),
        "vel":       np.array([0.0, v0_init, 0.0]),
        "trail":     [],
        "running":   True,
        "fall_stop": False,
    }

    fig = plt.figure(figsize=(12, 8))
    fig.patch.set_facecolor(C["bg_deep"])

    ax = fig.add_axes([0.05, 0.15, 0.60, 0.75], projection='3d')
    ax.set_facecolor(C["bg_deep"])
    ax.set_title("ORBITA ALREDEDOR DE UN AGUJERO NEGRO", fontsize=14,
                color=C["text_hi"], fontfamily='monospace', pad=20)
    ax.set_xlabel("X (uds)", fontsize=9, color=C["text_lo"])
    ax.set_ylabel("Y (uds)", fontsize=9, color=C["text_lo"])
    ax.set_zlabel("Z (uds)", fontsize=9, color=C["text_lo"])
    ax.tick_params(colors=C["text_lo"], labelsize=7)
    ax.set_xlim(-6, 6)
    ax.set_ylim(-6, 6)
    ax.set_zlim(-3, 3)

    u = np.linspace(0, 2 * np.pi, 50)
    v = np.linspace(0, np.pi, 30)
    x_sphere = horizon * np.outer(np.cos(u), np.sin(v))
    y_sphere = horizon * np.outer(np.sin(u), np.sin(v))
    z_sphere = horizon * np.outer(np.ones_like(u), np.cos(v))
    ax.plot_surface(x_sphere, y_sphere, z_sphere, color='black', alpha=0.9,
                    edgecolor='none', zorder=1)

    theta_accretion = np.linspace(0, 2*np.pi, 100)
    r_accretion = np.linspace(0.6, 1.2, 20)
    R, Theta = np.meshgrid(r_accretion, theta_accretion)
    X_acc = R * np.cos(Theta)
    Y_acc = R * np.sin(Theta)
    Z_acc = np.zeros_like(X_acc) * 0.05
    ax.plot_surface(X_acc, Y_acc, Z_acc, color=C["accent"], alpha=0.3,
                    edgecolor='none', zorder=0)

    ring_theta = np.linspace(0, 2*np.pi, 200)
    ring_x = 0.9 * np.cos(ring_theta)
    ring_y = 0.9 * np.sin(ring_theta)
    ring_z = np.zeros_like(ring_theta)
    ax.plot(ring_x, ring_y, ring_z, color=C["accent2"], lw=2, alpha=0.8)

    ship_point, = ax.plot([], [], [], 'ro', markersize=8, zorder=5)
    trail_line, = ax.plot([], [], [], color=C["accent"], lw=1, alpha=0.7)

    status_text = fig.text(0.05, 0.02, "", fontsize=9,
                        color=C["text_hi"], fontfamily='monospace')

    # Etiquetas con valores en tiempo real de radio y velocidad
    label_r = fig.text(0.68, 0.92,
                    "Radio (r):  ---",
                    fontsize=10, color=C["accent"],
                    fontfamily='monospace', fontweight='bold')
    label_v = fig.text(0.68, 0.88,
                    "Velocidad (|v|):  ---",
                    fontsize=10, color=C["accent3"],
                    fontfamily='monospace', fontweight='bold')

    # Sliders en el panel derecho
    ax_slider_r = plt.axes([0.70, 0.78, 0.25, 0.028], facecolor=C["bg_panel"])
    ax_slider_v = plt.axes([0.70, 0.70, 0.25, 0.028], facecolor=C["bg_panel"])

    slider_r = Slider(
        ax_slider_r,
        "Radio inicial r0",
        1.5, 8.0,
        valinit=r0, valstep=0.1,
        color=C["accent"]
    )
    slider_r.label.set_color(C["text_lo"])
    slider_r.label.set_fontsize(8)
    slider_r.valtext.set_color(C["accent"])

    slider_v = Slider(
        ax_slider_v,
        "Velocidad inicial v0",
        0.0, 2.5,
        valinit=v0_init, valstep=0.01,
        color=C["accent3"]
    )
    slider_v.label.set_color(C["text_lo"])
    slider_v.label.set_fontsize(8)
    slider_v.valtext.set_color(C["accent3"])

    fig.text(0.70, 0.815,
            "Mayor r0 = orbita mas amplia",
            fontsize=7, color=C["text_lo"], fontfamily='monospace')
    fig.text(0.70, 0.735,
            "Mayor v0 = mas energia (escape/elipse)",
            fontsize=7, color=C["text_lo"], fontfamily='monospace')

    # Botones Play / Pause / Reset
    ax_play  = plt.axes([0.70, 0.59, 0.07, 0.050])
    ax_pause = plt.axes([0.79, 0.59, 0.07, 0.050])
    ax_reset = plt.axes([0.88, 0.59, 0.07, 0.050])

    btn_play  = Button(ax_play,  "PLAY",  color=C["bg_panel"], hovercolor='#0d3a1a')
    btn_pause = Button(ax_pause, "PAUSE", color=C["bg_panel"], hovercolor='#3a2a0d')
    btn_reset = Button(ax_reset, "RESET", color=C["bg_panel"], hovercolor='#0d2d4a')

    for btn, col in [(btn_play, C["accent3"]), (btn_pause, C["warn"]), (btn_reset, C["accent"])]:
        btn.label.set_color(col)
        btn.label.set_fontsize(8)
        btn.label.set_fontfamily('monospace')

    fig.text(0.70, 0.555,
            "Teclado:  P = Play/Pause   R = Reset",
            fontsize=7, color=C["text_lo"], fontfamily='monospace')

    def do_reset(new_r0=None, new_v0=None):
        r0_new = new_r0 if new_r0 is not None else slider_r.val
        v0_new = new_v0 if new_v0 is not None else slider_v.val
        sim_state["pos"]       = np.array([r0_new, 0.0, 0.0])
        sim_state["vel"]       = np.array([0.0, v0_new, 0.0])
        sim_state["trail"]     = []
        sim_state["fall_stop"] = False
        sim_state["running"]   = True
        trail_line.set_data([], [])
        trail_line.set_3d_properties([])
        v_circ = np.sqrt(GM_bh / r0_new)
        v_esc  = np.sqrt(2 * GM_bh / r0_new)
        status_text.set_text(
            f"Referencia: v_circ = {v_circ:.3f}  |  v_esc = {v_esc:.3f}  |  Estado: Reiniciado"
        )

    def on_play(event=None):
        sim_state["running"]   = True
        sim_state["fall_stop"] = False

    def on_pause(event=None):
        sim_state["running"] = False

    def on_reset(event=None):
        do_reset()

    btn_play.on_clicked(on_play)
    btn_pause.on_clicked(on_pause)
    btn_reset.on_clicked(on_reset)

    def on_key(event):
        if event.key in ('p', 'P'):
            if sim_state["running"]:
                on_pause()
            else:
                on_play()
        elif event.key in ('r', 'R'):
            on_reset()

    fig.canvas.mpl_connect('key_press_event', on_key)

    def update(frame):
        state = sim_state
        pos   = state["pos"]
        vel   = state["vel"]

        # Siempre actualizamos las etiquetas de radio y velocidad
        r_cur   = np.linalg.norm(pos)
        v_cur   = np.linalg.norm(vel)
        label_r.set_text(f"Radio actual (r):      {r_cur:.4f} uds")
        label_v.set_text(f"Velocidad actual (|v|): {v_cur:.4f} uds/s")

        if not state["running"] or state["fall_stop"]:
            return

        r = r_cur
        if r < horizon + 0.1:
            state["fall_stop"] = True
            status_text.set_text(
                "AVISO: LA NAVE HA CRUZADO EL HORIZONTE DE SUCESOS!\n"
                "Destruccion inevitable."
            )
            return

        a = -GM_bh / (r**3) * pos

        state["vel"] = vel + a * dt
        state["pos"] = pos + state["vel"] * dt

        state["trail"].append(state["pos"].copy())
        if len(state["trail"]) > 600:
            state["trail"].pop(0)

        ship_point.set_data([state["pos"][0]], [state["pos"][1]])
        ship_point.set_3d_properties([state["pos"][2]])

        if len(state["trail"]) > 1:
            trail_arr = np.array(state["trail"])
            trail_line.set_data(trail_arr[:, 0], trail_arr[:, 1])
            trail_line.set_3d_properties(trail_arr[:, 2])

        v_mag  = np.linalg.norm(state["vel"])
        v_circ = np.sqrt(GM_bh / r)
        v_esc  = np.sqrt(2 * GM_bh / r)

        if v_mag > v_esc:
            state_str = "ESCAPANDO  (velocidad > escape)"
        elif v_mag > v_circ:
            state_str = "Orbita eliptica / escapando?"
        else:
            state_str = "En orbita estable"

        status_text.set_text(
            f"r = {r:.3f} uds   |   |v| = {v_mag:.4f} uds/s\n"
            f"v_circ = {v_circ:.3f}   |   v_esc = {v_esc:.3f}\n"
            f"Estado: {state_str}"
        )

    # Intervalo reducido para mayor velocidad visual (de 20ms a 8ms)
    ani = FuncAnimation(fig, update, interval=8, cache_frame_data=False)
    plt.show()


