# ============================================================
# CONSTANTES Y PARÁMETROS
# ============================================================
GM     = 3.99e14
R_E    = 6.378e6
g0     = 9.8
omega  = 7.27e-5
m0     = 100.0
mp     = 10.0
T_def  = 1500.0
Isp    = 100.0
Cd     = 0.5
Aref   = 0.1
rho0   = 1.225
H      = 8500.0
T0_atm = 288.15
L      = 0.0065
R_air  = 287.05

# ============================================================
# ATMÓSFERA ISA  — CORREGIDA: usa T0_atm y hace return rho
# ============================================================
def density_at_altitude(z):
    z = max(z, 0.0)
    z_km = z / 1000.0

    if z_km < 11:                          # Tropósfera 0-11 km
        T   = T0_atm - L * z              # BUG 1 CORREGIDO: T0_atm
        p   = 101325.0 * (T / T0_atm) ** (g0 / (L * R_air))
        rho = p / (R_air * T)

    elif z_km < 20:                        # Estratósfera baja 11-20 km
        T     = 216.65
        p_11  = 22632.1
        h     = z - 11000.0
        p     = p_11 * np.exp(-g0 * h / (R_air * T))
        rho   = p / (R_air * T)

    elif z_km < 32:                        # Estratósfera alta 20-32 km
        T     = 216.65 + 0.001 * (z - 20000.0)
        p_20  = 5474.89
        h     = z - 20000.0
        T_avg = (216.65 + T) / 2.0
        p     = p_20 * np.exp(-g0 * h / (R_air * T_avg))
        rho   = p / (R_air * T)

    elif z_km < 47:                        # Mesósfera 32-47 km
        T     = 228.65 + 0.0028 * (z - 32000.0)
        p_32  = 868.02
        h     = z - 32000.0
        T_avg = (228.65 + T) / 2.0
        p     = p_32 * np.exp(-g0 * h / (R_air * T_avg))
        rho   = p / (R_air * T)

    elif z_km < 51:                        # Mesósfera alta 47-51 km
        T     = 270.65
        p_47  = 110.91
        h     = z - 47000.0
        p     = p_47 * np.exp(-g0 * h / (R_air * T))
        rho   = p / (R_air * T)

    elif z_km < 71:                        # Termósfera baja 51-71 km
        T     = 270.65 + 0.0028 * (z - 51000.0)
        p_51  = 66.939
        h     = z - 51000.0
        T_avg = (270.65 + T) / 2.0
        p     = p_51 * np.exp(-g0 * h / (R_air * T_avg))
        rho   = p / (R_air * T)

    elif z_km < 85:                        # Termósfera alta 71-85 km
        T     = 270.65 + 0.002 * (z - 71000.0)
        p_71  = 3.9564
        h     = z - 71000.0
        T_avg = (270.65 + T) / 2.0
        p     = p_71 * np.exp(-g0 * h / (R_air * T_avg))
        rho   = p / (R_air * T)

    else:                                  # > 85 km: modelo exponencial
        rho = 1.5e-5 * np.exp(-(z - 85000.0) / 6000.0)

    return rho   # BUG 2-3 CORREGIDO: return único fuera del if/elif


# ============================================================
# SIMULACIÓN CON EULER  — CORREGIDA: ventana ciega & return
# ============================================================
def simulate(T_thrust=1500.0, omega_sim=omega, m_propellant=None,
             use_ISA=True, angle_deg=5.0):
    if m_propellant is None:
        m_propellant = m0 - mp            # 90 kg por defecto

    t_burnout = m_propellant * g0 * Isp / T_thrust
    dt        = 0.1
    tfinal    = 600.0
    t_arr     = np.arange(0, tfinal, dt)
    N         = len(t_arr)

    pos      = np.zeros((N, 3))
    vel      = np.zeros((N, 3))
    mass     = np.zeros(N)
    drag_arr = np.zeros(N)

    # Ángulo de inclinación respecto a la vertical
    angle_rad = np.radians(angle_deg)
    v0        = 10.0
    pos[0]    = [0.0, 0.0, 0.0]
    vel[0]    = [np.sin(angle_rad) * v0, 0.0, np.cos(angle_rad) * v0]
    mass[0]   = m0

    omega_vec = np.array([0.0, 0.0, omega_sim])
    idx_land  = N - 1

    for i in range(1, N):
        z_prev = pos[i-1, 2]
        v_prev = vel[i-1]
        m_prev = mass[i-1]
        t_prev = t_arr[i-1]

        # Gravedad variable con altitud
        g_z    = -GM / (R_E + max(z_prev, 0.0)) ** 2
        a_grav = np.array([0.0, 0.0, g_z])

        # Arrastre
        rho   = density_at_altitude(z_prev) if use_ISA else rho0 * np.exp(-z_prev / H)
        v_mag = np.linalg.norm(v_prev)
        if v_mag > 0:
            a_drag    = -0.5 * Cd * Aref * rho * v_mag * v_prev / m_prev
            drag_force = 0.5 * Cd * Aref * rho * v_mag ** 2
        else:
            a_drag     = np.zeros(3)
            drag_force = 0.0
        drag_arr[i-1] = drag_force

        # Empuje en dirección de la velocidad inicial (ángulo fijo)
        burning  = t_prev < t_burnout
        thrust_dir = np.array([np.sin(angle_rad), 0.0, np.cos(angle_rad)])
        a_thrust = (T_thrust / m_prev) * thrust_dir if burning else np.zeros(3)
        mdot     = -T_thrust / (g0 * Isp) if burning else 0.0

        # Coriolis
        a_coriolis = -2.0 * np.cross(omega_vec, v_prev)

        a_total = a_grav + a_drag + a_thrust + a_coriolis
        vel[i]  = v_prev + a_total * dt
        pos[i]  = pos[i-1] + v_prev * dt
        mass[i] = max(m_prev + mdot * dt, mp)

        # BUG 5 CORREGIDO: detectar aterrizaje desde i=2 (0.2 s)
        if i > 2 and pos[i, 2] <= 0.0:
            idx_land = i
            break

    t_out    = t_arr[:idx_land + 1]
    pos_out  = pos[:idx_land + 1]
    vel_out  = vel[:idx_land + 1]
    drag_out = drag_arr[:idx_land + 1]

    return {
        "t":       t_out,
        "pos":     pos_out,
        "vel":     np.linalg.norm(vel_out, axis=1),
        "drag":    drag_out,
        "alt":     pos_out[:, 2],
        "max_alt": np.max(pos_out[:, 2]),
        "tf":      t_out[-1],
        "xf":      pos_out[-1, 0],
        "yf":      pos_out[-1, 1],
    }


