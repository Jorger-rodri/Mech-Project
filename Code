    current_view = "altitud"
    clear_main()
    b = sims["base"]
    ax_main.plot(b["t"], b["alt"] / 1000, color=COLORS["base"], lw=2)
    ax_main.fill_between(b["t"], b["alt"] / 1000, alpha=0.12, color=COLORS["base"])
    style_ax(ax_main, 'Tiempo (s)', 'Altitud (km)', 'Altitud vs Tiempo')
    update_info()
    fig.canvas.draw_idle()

