def update_info():
    b = sims["base"]
    rng = np.sqrt(b["xf"]**2 + b["yf"]**2)
    info_text.set_text(
        f"Ángulo: {current_angle:.1f}°  |  "
        f"Alt. máx: {b['max_alt']/1000:.2f} km  |  "
        f"Tiempo vuelo: {b['tf']:.1f} s  |  "
        f"Rango: {rng:.1f} m  |  "
        f"Vel. máx: {np.max(b['vel']):.1f} m/s"
    )

