#  SIMULACIÓN ORBITAL ALREDEDOR DE UN AGUJERO NEGRO
# ══════════════════════════════════════════════════════════════════

def black_hole_simulation():
    """
    Simulación interactiva 3D de una nave orbitando un agujero negro.
    Parámetros ajustables: distancia inicial (r0) y velocidad tangencial (v0).
    Muestra si la nave cae, orbita o escapa.
    """
    # Parámetros físicos (unidades normalizadas)
    GM_bh = 1.0          # Parámetro gravitacional (escala visual)
    horizon = 0.5        # Radio del horizonte de sucesos

    # Configuración de la animación
    speed = 20.0         # Factor de aceleración temporal
    dt = 0.01 * speed    # Paso de tiempo integración

    # Estado inicial (se actualizará con sliders)
    r0 = 3.0
    v0 = np.sqrt(GM_bh / r0)   # velocidad circular

    pos = np.array([r0, 0.0, 0.0])
    vel = np.array([0.0, v0, 0.0])
    trail = []           # lista de posiciones para la estela

    # Crear figura y ejes 3D
    fig = plt.figure(figsize=(12, 8))
    fig.patch.set_facecolor(C["bg_deep"])
    ax = fig.add_axes([0.05, 0.15, 0.70, 0.75], projection='3d')
    ax.set_facecolor(C["bg_deep"])
    ax.set_title("ÓRBITA ALREDEDOR DE UN AGUJERO NEGRO", fontsize=14,
                 color=C["text_hi"], fontfamily='monospace', pad=20)
    ax.set_xlabel("X (uds)", fontsize=9, color=C["text_lo"])
    ax.set_ylabel("Y (uds)", fontsize=9, color=C["text_lo"])
    ax.set_zlabel("Z (uds)", fontsize=9, color=C["text_lo"])
    ax.tick_params(colors=C["text_lo"], labelsize=7)

    # Límites de la escena
    ax.set_xlim(-6, 6)
    ax.set_ylim(-6, 6)
    ax.set_zlim(-3, 3)

    # Dibujar agujero negro (esfera negra con anillo de acreción)
    u = np.linspace(0, 2 * np.pi, 50)
    v = np.linspace(0, np.pi, 30)
    x_sphere = horizon * np.outer(np.cos(u), np.sin(v))
    y_sphere = horizon * np.outer(np.sin(u), np.sin(v))
    z_sphere = horizon * np.outer(np.ones_like(u), np.cos(v))
    ax.plot_surface(x_sphere, y_sphere, z_sphere, color='black', alpha=0.9,
                    edgecolor='none', zorder=1)

    # Anillo de acreción (disco brillante)
    theta_accretion = np.linspace(0, 2*np.pi, 100)
    r_accretion = np.linspace(0.6, 1.2, 20)
    R, Theta = np.meshgrid(r_accretion, theta_accretion)
    X_acc = R * np.cos(Theta)
    Y_acc = R * np.sin(Theta)
    Z_acc = np.zeros_like(X_acc) * 0.05
    ax.plot_surface(X_acc, Y_acc, Z_acc, color=C["accent"], alpha=0.3,
                    edgecolor='none', zorder=0)
    # Aro brillante
    ring_theta = np.linspace(0, 2*np.pi, 200)
    ring_x = 0.9 * np.cos(ring_theta)
    ring_y = 0.9 * np.sin(ring_theta)
    ring_z = np.zeros_like(ring_theta)
    ax.plot(ring_x, ring_y, ring_z, color=C["accent2"], lw=2, alpha=0.8)

    # Nave (punto rojo)
    ship_point, = ax.plot([], [], [], 'ro', markersize=8, zorder=5)
    trail_line, = ax.plot([], [], [], color=C["accent"], lw=1, alpha=0.7)

    # Texto de estado
    status_text = fig.text(0.05, 0.02, "", fontsize=10,
                           color=C["text_hi"], fontfamily='monospace')

    # Sliders y botón (colocados en el lado derecho) - con etiquetas claras
    ax_slider_r = plt.axes([0.78, 0.75, 0.18, 0.03], facecolor=C["bg_panel"])
    ax_slider_v = plt.axes([0.78, 0.68, 0.18, 0.03], facecolor=C["bg_panel"])
    slider_r = Slider(ax_slider_r, "Radio inicial (r0) [uds]", 1.5, 8.0,
                      valinit=r0, valstep=0.1, color=C["accent"])
    slider_v = Slider(ax_slider_v, "Velocidad tangencial (v0) [uds/s]", 0.0, 2.5,
                      valinit=v0, valstep=0.01, color=C["accent"])

    # Añadir texto explicativo de los sliders
    fig.text(0.78, 0.80, "↑ MAYOR radio = órbita más amplia, menos atracción",
             fontsize=7, color=C["text_lo"], fontfamily='monospace')
    fig.text(0.78, 0.73, "↑ MAYOR velocidad = más energía (escape o elipse)",
             fontsize=7, color=C["text_lo"], fontfamily='monospace')

    # Botón de reinicio
    ax_reset = plt.axes([0.78, 0.60, 0.18, 0.05])
    reset_btn = Button(ax_reset, "RESET", color=C["bg_panel"], hovercolor='#0d2d4a')
    reset_btn.label.set_color(C["accent"])
    reset_btn.label.set_fontsize(8)

    # Variables de control de animación
    running = True
    fall_stop = False

    def reset_sim(event=None):
        nonlocal pos, vel, trail, running, fall_stop
        r0_new = slider_r.val
        v0_new = slider_v.val
        pos = np.array([r0_new, 0.0, 0.0])
        vel = np.array([0.0, v0_new, 0.0])
        trail = []
        fall_stop = False
        running = True
        # Actualizar texto de referencia
        v_circ = np.sqrt(GM_bh / r0_new)
        v_esc = np.sqrt(2 * GM_bh / r0_new)
        status_text.set_text(
            f"Referencia: v_circ = {v_circ:.3f}  |  v_esc = {v_esc:.3f}\n"
            f"Estado: Reiniciado"
        )
        # Limpiar estela
        trail_line.set_data([], [])
        trail_line.set_3d_properties([])

    reset_btn.on_clicked(reset_sim)

    # Función de actualización de la animación
    def update(frame):
        nonlocal pos, vel, trail, running, fall_stop
        if not running or fall_stop:
            return

        r = np.linalg.norm(pos)
        if r < horizon + 0.1:
            fall_stop = True
            status_text.set_text(
                f"⚠️  ¡LA NAVE HA CRUZADO EL HORIZONTE!\n"
                f"Destrucción inevitable."
            )
            return

        # Aceleración gravitacional (newtoniana)
        a = -GM_bh / (r**3) * pos

        # Integración Euler
        vel += a * dt
        pos += vel * dt

        # Guardar trayectoria
        trail.append(pos.copy())
        if len(trail) > 500:
            trail.pop(0)

        # Actualizar gráficos
        ship_point.set_data([pos[0]], [pos[1]])
        ship_point.set_3d_properties([pos[2]])
        if len(trail) > 1:
            trail_arr = np.array(trail)
            trail_line.set_data(trail_arr[:, 0], trail_arr[:, 1])
            trail_line.set_3d_properties(trail_arr[:, 2])

        # Calcular velocidades características
        v_mag = np.linalg.norm(vel)
        v_circ = np.sqrt(GM_bh / r)
        v_esc = np.sqrt(2 * GM_bh / r)
        if v_mag > v_esc:
            state = "🚀 ¡ESCAPANDO!  (velocidad superior a escape)"
        elif v_mag > v_circ:
            state = "🛰️  Órbita elíptica / escapando?"
        else:
            state = "🛸 En órbita estable"

        status_text.set_text(
            f"r = {r:.2f}   |   v = {v_mag:.3f}\n"
            f"v_circ = {v_circ:.3f}   v_esc = {v_esc:.3f}\n"
            f"{state}"
        )

    # Iniciar animación
    ani = FuncAnimation(fig, update, interval=20, cache_frame_data=False)
    plt.show()

