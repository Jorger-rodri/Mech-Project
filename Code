def draw_stars(ax, n=300):
    """Genera un campo de estrellas aleatorio en el fondo."""
    np.random.seed(42)
    xs  = np.random.uniform(0, 1, n)
    ys  = np.random.uniform(0, 1, n)
    sz  = np.random.exponential(0.8, n) + 0.2
    alp = np.random.uniform(0.3, 1.0, n)
    ax.scatter(xs, ys, s=sz, c='white', alpha=alp,
            transform=ax.transAxes, zorder=1)


def draw_earth_arc(ax):
    """Dibuja un arco de la Tierra en la parte inferior."""
    theta  = np.linspace(np.pi * 1.1, np.pi * 1.9, 300)
    r      = 0.38
    cx, cy = 0.5, -0.25
    x = cx + r * np.cos(theta)
    y = cy + r * np.sin(theta)
    ax.fill_between(
        x, y, -0.3,
        color='#0a2a4a', alpha=0.9,
        transform=ax.transAxes, zorder=2
    )
    ax.plot(x, y, color='#1a6fa0', lw=1.5,
            alpha=0.8, transform=ax.transAxes, zorder=3)
    for i, (r_off, alp) in enumerate([(0.005, 0.15), (0.010, 0.10), (0.018, 0.05)]):
        xg = cx + (r + r_off) * np.cos(theta)
        yg = cy + (r + r_off) * np.sin(theta)
        ax.plot(xg, yg, color='#00aaff', lw=2 + i,
                alpha=alp, transform=ax.transAxes, zorder=2)


