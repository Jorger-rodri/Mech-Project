def style_ax(ax, xlabel, ylabel, title):
    ax.set_facecolor('#0f0f23')
    ax.tick_params(colors='#8899aa', labelsize=9)
    ax.xaxis.label.set_color('#8899aa')
    ax.yaxis.label.set_color('#8899aa')
    ax.set_xlabel(xlabel,fontsize=10)
    ax.set_ylabel(ylabel, fontsize=10)
    ax.set_title(title, fontsize=11, color='white', pad=6)
    ax.grid(True, alpha=0.15, color='white')
    for spine in ax.spines.values():
        spine.set_edgecolor('#334455')

def clear_main():
    global ax_3d
    # BUG 6 CORREGIDO: eliminar ejes 3D correctamente
    if ax_3d is not None:
        fig.delaxes(ax_3d)
        ax_3d = None
    ax_main.cla()
    ax_main.set_visible(True)
    ax_main.set_facecolor('#0f0f23')

