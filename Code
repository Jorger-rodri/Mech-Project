# ══════════════════════════════════════════════════════════════════
#  CONSTANTES Y PARÁMETROS DEL COHETE
# ══════════════════════════════════════════════════════════════════

GM     = 3.99e14   # Parámetro gravitacional estándar [m³/s²]
R_E    = 6.378e6   # Radio medio de la Tierra          [m]
g0     = 9.8       # Gravedad estándar al nivel del mar [m/s²]
omega  = 7.27e-5   # Velocidad angular de la Tierra     [rad/s]

m0     = 100.0     # Masa total inicial                 [kg]
mp     = 10.0      # Masa de estructura (seca)          [kg]
T_def  = 1500.0    # Empuje nominal                     [N]
Isp    = 100.0     # Impulso específico                 [s]
Cd     = 0.5       # Coeficiente de arrastre            [—]
Aref   = 0.1       # Área de referencia                 [m²]

rho0   = 1.225     # Densidad al nivel del mar          [kg/m³]
H      = 8500.0    # Altura de escala                   [m]

T0_atm = 288.15    # Temperatura al nivel del mar       [K]
L      = 0.0065    # Gradiente térmico troposférico     [K/m]
R_air  = 287.05    # Constante del aire                 [J/(kg·K)]

# ══════════════════════════════════════════════════════════════════
#  ATMÓSFERA ISA — modelo multicapa (0–85 km)
# ══════════════════════════════════════════════════════════════════

def density_at_altitude(z):
    """Densidad ISA [kg/m³] en función de la altitud z [m]."""
    z    = max(z, 0.0)
    z_km = z / 1000.0

    if z_km < 11:
        T   = T0_atm - L * z
        p   = 101325.0 * (T / T0_atm) ** (g0 / (L * R_air))
        rho = p / (R_air * T)
    elif z_km < 20:
        T     = 216.65
        p_11  = 22632.1
        h     = z - 11000.0
        p     = p_11 * np.exp(-g0 * h / (R_air * T))
        rho   = p / (R_air * T)
    elif z_km < 32:
        T     = 216.65 + 0.001 * (z - 20000.0)
        p_20  = 5474.89
        h     = z - 20000.0
        T_avg = (216.65 + T) / 2.0
        p     = p_20 * np.exp(-g0 * h / (R_air * T_avg))
        rho   = p / (R_air * T)
    elif z_km < 47:
        T     = 228.65 + 0.0028 * (z - 32000.0)
        p_32  = 868.02
        h     = z - 32000.0
        T_avg = (228.65 + T) / 2.0
        p     = p_32 * np.exp(-g0 * h / (R_air * T_avg))
        rho   = p / (R_air * T)
    elif z_km < 51:
        T     = 270.65
        p_47  = 110.91
        h     = z - 47000.0
        p     = p_47 * np.exp(-g0 * h / (R_air * T))
        rho   = p / (R_air * T)
    elif z_km < 71:
        T     = 270.65 + 0.0028 * (z - 51000.0)
        p_51  = 66.939
        h     = z - 51000.0
        T_avg = (270.65 + T) / 2.0
        p     = p_51 * np.exp(-g0 * h / (R_air * T_avg))
        rho   = p / (R_air * T)
    elif z_km < 85:
        T     = 270.65 + 0.002 * (z - 71000.0)
        p_71  = 3.9564
        h     = z - 71000.0
        T_avg = (270.65 + T) / 2.0
        p     = p_71 * np.exp(-g0 * h / (R_air * T_avg))
        rho   = p / (R_air * T)
    else:
        rho = 1.5e-5 * np.exp(-(z - 85000.0) / 6000.0)

    return rho

# ══════════════════════════════════════════════════════════════════
#  SIMULACIÓN NUMÉRICA DEL COHETE — Integración de Euler
# ══════════════════════════════════════════════════════════════════

def simulate(T_thrust=1500.0, omega_sim=omega, m_propellant=None,
             use_ISA=True, angle_deg=5.0):
    """Integra las ecuaciones de movimiento con el método de Euler."""
    if m_propellant is None:
        m_propellant = m0 - mp

    t_burnout = m_propellant * g0 * Isp / T_thrust
    dt        = 0.1
    tfinal    = 600.0
    t_arr     = np.arange(0, tfinal, dt)
    N         = len(t_arr)

    pos      = np.zeros((N, 3))
    vel      = np.zeros((N, 3))
    mass     = np.zeros(N)
    drag_arr = np.zeros(N)

    angle_rad = np.radians(angle_deg)
    v0        = 10.0
    pos[0]    = [0.0, 0.0, 0.0]
    vel[0]    = [np.sin(angle_rad) * v0, 0.0, np.cos(angle_rad) * v0]
    mass[0]   = m0

    omega_vec = np.array([0.0, 0.0, omega_sim])
    idx_land  = N - 1

    for i in range(1, N):
        z_prev = pos[i-1, 2]
        v_prev = vel[i-1]
        m_prev = mass[i-1]
        t_prev = t_arr[i-1]

        g_z    = -GM / (R_E + max(z_prev, 0.0)) ** 2
        a_grav = np.array([0.0, 0.0, g_z])

        rho   = density_at_altitude(z_prev) if use_ISA else rho0 * np.exp(-z_prev / H)
        v_mag = np.linalg.norm(v_prev)
        if v_mag > 0:
            a_drag     = -0.5 * Cd * Aref * rho * v_mag * v_prev / m_prev
            drag_force =  0.5 * Cd * Aref * rho * v_mag ** 2
        else:
            a_drag     = np.zeros(3)
            drag_force = 0.0
        drag_arr[i-1] = drag_force

        burning    = t_prev < t_burnout
        thrust_dir = np.array([np.sin(angle_rad), 0.0, np.cos(angle_rad)])
        a_thrust   = (T_thrust / m_prev) * thrust_dir if burning else np.zeros(3)
        mdot       = -T_thrust / (g0 * Isp)           if burning else 0.0

        a_coriolis = -2.0 * np.cross(omega_vec, v_prev)

        a_total = a_grav + a_drag + a_thrust + a_coriolis
        vel[i]  = v_prev + a_total * dt
        pos[i]  = pos[i-1] + v_prev * dt
        mass[i] = max(m_prev + mdot * dt, mp)

        if i > 2 and pos[i, 2] <= 0.0:
            idx_land = i
            break

    t_out    = t_arr[:idx_land + 1]
    pos_out  = pos[:idx_land + 1]
    vel_out  = vel[:idx_land + 1]
    drag_out = drag_arr[:idx_land + 1]

    return {
        "t":       t_out,
        "pos":     pos_out,
        "vel":     np.linalg.norm(vel_out, axis=1),
        "drag":    drag_out,
        "alt":     pos_out[:, 2],
        "max_alt": np.max(pos_out[:, 2]),
        "tf":      t_out[-1],
        "xf":      pos_out[-1, 0],
        "yf":      pos_out[-1, 1],
    }

