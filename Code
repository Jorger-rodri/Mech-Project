def add_hud_border(ax_obj):
    """Anade esquinas decorativas HUD alrededor de un axes."""
    fig_obj = ax_obj.get_figure()
    pos     = ax_obj.get_position()
    x0, y0  = pos.x0, pos.y0
    x1, y1  = pos.x1, pos.y1
    seg     = 0.025
    corners = [
        ([x0, x0 + seg], [y1, y1]),
        ([x0, x0],       [y1, y1 - seg]),
        ([x1 - seg, x1], [y1, y1]),
        ([x1, x1],       [y1, y1 - seg]),
        ([x0, x0 + seg], [y0, y0]),
        ([x0, x0],       [y0, y0 + seg]),
        ([x1 - seg, x1], [y0, y0]),
        ([x1, x1],       [y0, y0 + seg]),
    ]
    for (xs, ys) in corners:
        fig_obj.add_artist(
            plt.Line2D(xs, ys, color=C["accent"], lw=1.5,
                    alpha=0.7, transform=fig_obj.transFigure, zorder=10)
        )


