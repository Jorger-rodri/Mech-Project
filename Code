def run_all_sims(angle_deg):
    global sims
    sims["base"]   = simulate(angle_deg=angle_deg)
    sims["noC"]    = simulate(omega_sim=0.0,        angle_deg=angle_deg)
    sims["T1000"]  = simulate(T_thrust=1000.0,      angle_deg=angle_deg)
    sims["T3000"]  = simulate(T_thrust=3000.0,      angle_deg=angle_deg)
    sims["expAtm"] = simulate(use_ISA=False,         angle_deg=angle_deg)
    sims["mp10"]   = simulate(m_propellant=10.0,    angle_deg=angle_deg)
    sims["mp50"]   = simulate(m_propellant=50.0,    angle_deg=angle_deg)
    sims["mp90"]   = simulate(m_propellant=90.0,    angle_deg=angle_deg)

