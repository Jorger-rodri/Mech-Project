        count_text.set_color(C["accent2"] if i <= 3 else C["accent"])
        label_text.set_color(C["accent2"] if i <= 0 else C["text_lo"])

        bar_fill.set_width(0.40 * frac)

        msg_idx = min(total - i, len(status_msgs) - 1)
        status_text.set_text(status_msgs[msg_idx])
        status_text.set_color(status_colors[msg_idx])

        fig_cd.canvas.draw()
        fig_cd.canvas.flush_events()
        time.sleep(1.0)

    time.sleep(0.4)
    plt.close(fig_cd)
    plt.ioff()


def style_ax(ax, xlabel, ylabel, title):
    """Aplica el tema HUD espacial a un eje 2D."""
    ax.set_facecolor(C["bg_plot"])
    ax.tick_params(colors=C["text_lo"], labelsize=8.5)
    ax.xaxis.label.set_color(C["text_lo"])
    ax.yaxis.label.set_color(C["text_lo"])
    ax.set_xlabel(xlabel, fontsize=9.5, fontfamily='monospace')
    ax.set_ylabel(ylabel, fontsize=9.5, fontfamily='monospace')
    ax.set_title(title, fontsize=10.5, color=C["text_hi"],
                pad=7, fontfamily='monospace', fontweight='bold')
    ax.grid(True, alpha=0.12, color=C["accent"], linestyle='--', linewidth=0.5)
    for spine in ax.spines.values():
        spine.set_edgecolor(C["accent"])
        spine.set_linewidth(0.8)
        spine.set_alpha(0.5)


